<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardVoucher"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="6dp"
    app:strokeWidth="0dp"
    app:strokeColor="#4CAF50">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:background="@color/white">

        <!-- Label Sedang Digunakan -->
        <TextView
            android:id="@+id/tvUsedLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#4CAF50"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="Sedang Digunakan"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Left Section (Discount) -->
        <RelativeLayout
            android:id="@+id/layoutLeft"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_voucher_left_gradient"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvVoucherValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15%"
                    android:textColor="@color/white"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.9"
                    android:text="OFF"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Top Notch -->
            <View
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="-10dp"
                android:layout_marginEnd="-10dp"
                android:background="@drawable/bg_voucher_circle_notch" />

            <!-- Bottom Notch -->
            <View
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentBottom="true"
                android:layout_alignParentEnd="true"
                android:layout_marginBottom="-10dp"
                android:layout_marginEnd="-10dp"
                android:background="@drawable/bg_voucher_circle_notch" />
        </RelativeLayout>

        <!-- Right Section (Details) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:gravity="center_vertical"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnClaim"
            app:layout_constraintStart_toEndOf="@id/layoutLeft"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvVoucherName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="GAJIANNIH"
                android:textColor="#212121"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVoucherDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Potongan diskon hingga Rp 50.000"
                android:textColor="#757575"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvMinPurchase"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Min. Belanja Rp 75.000"
                android:textColor="#EE4D2D"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVoucherStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Voucher tersedia"
                android:textColor="#4CAF50"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvLimitedTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="#FFE0B2"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="LIMITED"
                android:textColor="#F57C00"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnClaim"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_btn_pill"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Klaim"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
