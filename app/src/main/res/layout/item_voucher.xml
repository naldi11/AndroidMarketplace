<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="160dp"
    android:layout_marginEnd="16dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/bg_gradient_orange"
    android:elevation="4dp">

    <!-- Left Section -->
    <LinearLayout
        android:id="@+id/leftSection"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintEnd_toStartOf="@id/notchDivider"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvPromoSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#33FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="PROMO SPESIAL"
            android:textAllCaps="true"
            android:textColor="#FFFFFF"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/tvPromoTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-black"
            android:maxLines="1"
            android:text="DISKON 10%"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPromoDiscount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif"
            android:maxLines="1"
            android:text="Potongan hingga Rp50.000"
            android:textColor="#E0E0E0"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShopNow"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginTop="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingHorizontal="16dp"
            android:text="Pakai"
            android:textAllCaps="false"
            android:textColor="@color/primary_orange"
            android:textSize="12sp"
            android:textStyle="bold"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="16dp" />
    </LinearLayout>

    <!-- Dashed Line Divider -->
    <View
        android:id="@+id/notchDivider"
        android:layout_width="1.5dp"
        android:layout_height="0dp"
        android:layout_marginEnd="80dp"
        android:background="@drawable/bg_dashed_line_vertical"
        android:layerType="software"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top Cutout (Half Circle) -->
    <View
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/bg_circle_white"
        app:layout_constraintBottom_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="@id/notchDivider"
        app:layout_constraintStart_toStartOf="@id/notchDivider"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Bottom Cutout (Half Circle) -->
    <View
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/bg_circle_white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/notchDivider"
        app:layout_constraintStart_toStartOf="@id/notchDivider"
        app:layout_constraintTop_toBottomOf="parent" />

    <!-- Right Section -->
    <LinearLayout
        android:id="@+id/rightSection"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/notchDivider">

        <ImageView
            android:id="@+id/ivPromoIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_discount"
            app:tint="#40FFFFFF" />

        <TextView
            android:id="@+id/tvMinBelanja"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:maxLines="2"
            android:text="Min. Belanja\nRp100.000"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="9sp" />
            
        <TextView
            android:id="@+id/tvExpiry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="3 Hari Lagi"
            android:textColor="#FFCDD2"
            android:textSize="9sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
