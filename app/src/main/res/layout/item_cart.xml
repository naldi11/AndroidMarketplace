<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E0E0E0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Checkbox for multi-select -->
        <CheckBox
            android:id="@+id/cbCartItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <!-- Product Image -->
        <ImageView
            android:id="@+id/ivCartItemImage"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:scaleType="centerCrop"
            android:background="#EEEEEE"
            android:src="@mipmap/ic_launcher" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <!-- Title and Delete Button Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">
                
                <TextView
                    android:id="@+id/tvCartItemName"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Nama Produk"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <ImageButton
                    android:id="@+id/btnRemoveCartItem"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_delete"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Hapus dari Keranjang"
                    app:tint="@color/grey_icon"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvCartItemPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textColor="?attr/colorPrimary"
                android:layout_marginTop="4dp"/>

            <!-- Quantity Controls Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="end|center_vertical">
                
                <ImageButton
                    android:id="@+id/btnDecreaseQty"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_category_icon"
                    android:src="@drawable/ic_remove"
                    app:tint="@color/primary_orange"
                    android:contentDescription="Kurangi"
                    android:padding="8dp"/>
                    
                <TextView
                    android:id="@+id/tvCartItemQty"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textSize="14sp"/>

                <ImageButton
                    android:id="@+id/btnIncreaseQty"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_category_icon_selected"
                    android:src="@drawable/ic_add"
                    app:tint="@color/white"
                    android:contentDescription="Tambah"
                    android:padding="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
