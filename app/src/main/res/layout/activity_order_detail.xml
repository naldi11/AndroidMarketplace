<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary_orange"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:title="Detail Pesanan"
            app:titleTextColor="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:paddingBottom="88dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvShopName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Toko Penjual"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#1A1A1A" />

                            <TextView
                                android:id="@+id/tvOrderId"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="#INV-000"
                                android:textSize="11sp"
                                android:textColor="#888"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Belum Bayar"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_orange"
                            android:background="@drawable/bg_discount_badge"
                            android:backgroundTint="#FFF3E0"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="5dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvOrderDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="11 Maret 2026 · 10:00"
                        android:textSize="11sp"
                        android:textColor="#AAAAAA"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/tvRejectionReason"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="#FFF5F5"
                        android:padding="8dp"
                        android:text="Pembayaran ditolak: Bukti tidak terbaca"
                        android:textColor="#C62828"
                        android:textSize="12sp"
                        android:textStyle="italic"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Items Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Produk Dipesan"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#333"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:id="@+id/llItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Price Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ringkasan Pembayaran"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#333"
                        android:layout_marginBottom="10dp" />

                    <!-- Subtotal -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Subtotal Produk" android:textSize="13sp" android:textColor="#666" />
                        <TextView android:id="@+id/tvSubtotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textSize="13sp" android:textColor="#333" />
                    </LinearLayout>

                    <!-- Discount -->
                    <LinearLayout android:id="@+id/rowDiscount" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp" android:visibility="gone">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Diskon Voucher" android:textSize="13sp" android:textColor="#666" />
                        <TextView android:id="@+id/tvDiscount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="- Rp 0" android:textSize="13sp" android:textColor="#E53935" />
                    </LinearLayout>

                    <!-- Service Fee -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Biaya Layanan Platform" android:textSize="13sp" android:textColor="#666" />
                        <TextView android:id="@+id/tvServiceFee" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textSize="13sp" android:textColor="#333" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginBottom="12dp" />

                    <!-- Total -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Total Pembayaran" android:textSize="14sp" android:textStyle="bold" android:textColor="#1A1A1A" />
                        <TextView android:id="@+id/tvTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp 0" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/primary_orange" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Payment + Shipping Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Info Pembayaran &amp; Pengiriman"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#333"
                        android:layout_marginBottom="10dp" />

                    <!-- Payment Method -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="Metode Bayar" android:textSize="12sp" android:textColor="#888" />
                        <TextView android:id="@+id/tvPaymentMethod" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="-" android:textSize="12sp" android:textColor="#333" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Shipping Address -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="Alamat Pengiriman" android:textSize="12sp" android:textColor="#888" />
                        <TextView android:id="@+id/tvShippingAddress" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="-" android:textSize="12sp" android:textColor="#333" />
                    </LinearLayout>

                    <!-- Courier Info -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="Kurir / Tipe" android:textSize="12sp" android:textColor="#888" />
                        <TextView android:id="@+id/tvCourier" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="-" android:textSize="12sp" android:textColor="#333" />
                    </LinearLayout>

                    <!-- Tracking Number -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="Nomor Resi" android:textSize="12sp" android:textColor="#888" />
                        <TextView android:id="@+id/tvTrackingNumber" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="-" android:textSize="12sp" android:textColor="#333" android:textIsSelectable="true" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Proof of Payment Card (shown when uploaded) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProof"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvProofTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bukti Pembayaran"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#333"
                        android:layout_marginBottom="10dp" />

                    <ImageView
                        android:id="@+id/ivProofImage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="200dp"
                        android:scaleType="fitCenter"
                        android:adjustViewBounds="true"
                        android:background="#F5F5F5" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bukti Penerimaan (Multimedia dari Pembeli) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardReceiptProofs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bukti Penerimaan (dari Pembeli)"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#333"
                        android:layout_marginBottom="10dp" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/llReceiptProofs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Action Button (pinned) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:elevation="8dp"
        android:padding="16dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Batalkan"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:textColor="@color/primary_orange"
            app:strokeColor="@color/primary_orange"
            app:strokeWidth="1dp"
            app:backgroundTint="@color/white"
            app:cornerRadius="12dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAction"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:text="Bayar Sekarang"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:backgroundTint="@color/primary_orange"
            app:cornerRadius="12dp" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
