<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_white_rounded_16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pilih Metode Pembayaran"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnScanQRIS"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Scan Barcode / QRIS"
        android:textAllCaps="false"
        android:textStyle="bold"
        app:icon="@drawable/ic_scan"
        app:iconGravity="textStart"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/primary_orange"
        android:layout_marginBottom="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPayVA"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Bayar via VA MeyPay"
        android:textAllCaps="false"
        android:textStyle="bold"
        app:icon="@drawable/ic_wallet"
        app:iconGravity="textStart"
        app:cornerRadius="12dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/primary_orange"
        app:backgroundTint="@color/white"
        android:textColor="@color/primary_orange" />

</LinearLayout>
