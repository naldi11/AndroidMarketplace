<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp"
        android:paddingHorizontal="16dp">

        <!-- Left side: Icon & Distance -->
        <LinearLayout
            android:id="@+id/layoutLeft"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivSuggestionIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_location"
                android:contentDescription="Location icon"
                android:tint="#70757a" />

            <TextView
                android:id="@+id/tvSuggestionDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="11sp"
                android:textColor="#70757a"
                android:singleLine="true"
                android:text="0.0 km" />
        </LinearLayout>

        <!-- Right side: diagonal arrow -->
        <ImageView
            android:id="@+id/ivArrowUpRight"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_up_right"
            android:contentDescription="Use suggestion" />

        <!-- Center text parts -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@id/layoutLeft"
            android:layout_toLeftOf="@id/ivArrowUpRight"
            android:layout_centerVertical="true"
            android:layout_marginHorizontal="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSuggestionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#202124"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/tvSuggestionSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#5f6368"
                android:ellipsize="end"
                android:maxLines="1"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Divider starting after left column to match Google Maps style -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="80dp"
        android:background="#f1f3f4" />
</LinearLayout>
